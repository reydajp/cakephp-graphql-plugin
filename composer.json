{
    "name": "reydajp/cake-graphql",
    "description": "GraphQL endpoint plugin for CakePHP 5 using GraphQLite and Webonyx GraphQL PHP.",
    "type": "cakephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "reydajp"
        }
    ],
    "keywords": [
        "cakephp",
        "cakephp5",
        "graphql",
        "graphqlite",
        "webonyx",
        "cakephp-plugin"
    ],
    "require": {
        "php": ">=8.3",
        "cakephp/cakephp": "^5.0",
        "thecodingmachine/graphqlite": "^8.3",
        "webonyx/graphql-php": "^15.32"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "conflict": {
        "thecodingmachine/safe": "<3.4"
    },
    "autoload": {
        "psr-4": {
            "CakeGraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CakeGraphQL\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "config": {
        "allow-plugins": {
            "cakephp/plugin-installer": true
        },
        "sort-packages": true
    }
}
